# ==========================================
# Application
# ==========================================

APP_NAME=Inventory Order Management API
APP_ENV=development
DEBUG=true

# ==========================================
# Server
# ==========================================

HOST=0.0.0.0
PORT=8000

# ==========================================
# Database
# ==========================================

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_password

DATABASE_URL=postgresql+psycopg2://inventory_user:inventory_password@postgres:5432/inventory_db

# ==========================================
# CORS
# ==========================================

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# Pagination
# ==========================================

DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ==========================================
# Inventory Settings
# ==========================================

LOW_STOCK_THRESHOLD=10

# ==========================================
# Logging
# ==========================================

LOG_LEVEL=INFO